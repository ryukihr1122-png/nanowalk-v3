{
  "name": "nanowalk",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "build:dev": "eas build --platform ios --profile development",
    "build:preview": "eas build --platform ios --profile preview",
    "build:testflight": "eas build --platform ios --profile testflight",
    "build:production": "eas build --platform ios --profile production",
    "update:testflight": "eas update --channel testflight",
    "update:production": "eas update --channel production",
    "submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.46.0",
    "@tanstack/react-query": "^5.0.0",
    "date-fns": "^4.0.0",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-background-fetch": "~14.0.9",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-iap": "^1.0.0",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-sensors": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
